{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Disk Cleaner Clean Pack",
  "type": "object",
  "required": ["schemaVersion", "profile", "pack"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "generatedAt": { "type": "string" },
    "generator": { "type": "string" },
    "machineHint": { "type": "string" },
    "profile": {
      "type": "object",
      "properties": {
        "enabledBuiltInIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^C[0-9]{2}$" }
        },
        "disabledBuiltInIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^C[0-9]{2}$" }
        },
        "browserClearCookies": { "type": "boolean" },
        "extraRoots": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        },
        "comment": { "type": "string" }
      }
    },
    "pack": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "type": "object",
            "required": ["id", "label", "paths", "purpose", "deleteNote"],
            "properties": {
              "id": { "type": "string", "pattern": "^X[0-9]{2,}$" },
              "label": { "type": "string", "maxLength": 80 },
              "paths": {
                "type": "array",
                "minItems": 1,
                "maxItems": 20,
                "items": { "type": "string", "minLength": 3 }
              },
              "purpose": { "type": "string" },
              "deleteNote": { "type": "string" },
              "tag": { "type": "string" },
              "warn": { "type": "boolean" },
              "defaultChecked": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
